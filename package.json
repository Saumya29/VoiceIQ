{
  "name": "voiceiq",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "shared",
    "server",
    "client",
    "widget"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "npm run dev --workspace=server",
    "dev:client": "npm run dev --workspace=client",
    "build": "npm run build --workspace=shared && npm run build --workspace=server && npm run build --workspace=client && npm run build --workspace=widget",
    "build:shared": "npm run build --workspace=shared",
    "build:widget": "npm run build --workspace=widget"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  }
}
